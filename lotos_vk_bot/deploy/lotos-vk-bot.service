[Unit]
Description=Lotos VK Bot
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/lotos-vk-bot
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/ubuntu/lotos-vk-bot/venv/bin/python main.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
