# Опционально для локальной разработки (обычно достаточно personal_acc_lotos/.env).
# На Render задайте переменные в Dashboard → Environment.
# Скопируйте: copy .env.example .env
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=1755024
STUDIO_NAME=Лотос
YCLIENTS_BOOKING_URL=https://n1996926.yclients.com/
CORS_ORIGINS=http://localhost:5173
# Защищённый ключ мини-приложения VK (Настройки → Ключи доступа)
VK_APP_SECRET=
# Токен сообщества — для отправки кода входа в ЛС и ленты на главной
VK_GROUP_TOKEN=
# ID сообщества (без минуса), например 234626072
VK_GROUP_ID=
# Сервисный ключ мини-приложения VK — для wall.get (посты на главной)
VK_SERVICE_TOKEN=
# Запасные контакты студии, если VK не отдаёт адрес/часы
STUDIO_ADDRESS=
STUDIO_HOURS=
STUDIO_PHONE=
STUDIO_LATITUDE=
STUDIO_LONGITUDE=
# Локально без VK: SKIP_VK_SIGN=true (на Render не задавайте)
SKIP_VK_SIGN=true
# API по умолчанию на порту 8080 (npm run dev:api)
