# Vercel → Settings → Environment Variables → Production

# URL API на Render — без слэша в конце
VITE_API_BASE=https://your-api.onrender.com

# Для теста в браузере (не через VK): включите оба, затем Redeploy
# VITE_SKIP_VK_BRIDGE=true
# VITE_DEV_VK_USER_ID=123456789

# Для реальных пользователей в VK: не задавайте VITE_SKIP_VK_BRIDGE
