# Скопируйте в .env:  copy .env.example .env
# API читает этот файл автоматически (см. server/miniapp_config.py)

# --- Фронтенд (Vite) ---
VITE_SKIP_VK_BRIDGE=true
VITE_DEV_VK_USER_ID=1
# В dev API проксируется через Vite на localhost:8081 — оставьте VITE_API_BASE пустым.
# Не указывайте URL Render локально: без VPN onrender.com часто недоступен из РФ.
# На Vercel (прод): VITE_API_BASE=https://lotos-studio-app.onrender.com
VITE_API_BASE=

# --- YClients / API ---
YCLIENTS_PARTNER_TOKEN=
YCLIENTS_USER_TOKEN=
YCLIENTS_COMPANY_ID=1755024
STUDIO_NAME=Лотос
# Часовой пояс студии (UTC+5: Asia/Yekaterinburg, Asia/Tashkent)
STUDIO_TIMEZONE=Asia/Yekaterinburg
YCLIENTS_BOOKING_URL=https://n1996926.yclients.com/
CORS_ORIGINS=http://localhost:5173
SKIP_VK_SIGN=true
# Локально отключите keep-alive (на Render он включится сам через RENDER_EXTERNAL_URL)
KEEPALIVE_ENABLED=false
VK_APP_SECRET=
VK_GROUP_TOKEN=
VK_GROUP_ID=234626072
VK_SERVICE_TOKEN=
STUDIO_ADDRESS=
STUDIO_HOURS=
STUDIO_PHONE=
STUDIO_LATITUDE=
STUDIO_LONGITUDE=

# НЕ используйте Direct (db.xxx.supabase.co) — на Windows часто getaddrinfo failed.
# Dashboard → Project Settings → Database → Connect → URI → «Transaction pooler», порт 6543.
# Хост: aws-0-<region>.pooler.supabase.com  (не .supabase.co!)
# Пример: postgresql://postgres.hrxjtyijhcgtphtyhwxc:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Просмотр с телефона: npm run dev:mobile → http://<IP-ПК>:5173
